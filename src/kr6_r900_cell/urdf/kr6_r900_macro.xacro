<?xml version="1.0" encoding="UTF-8"?>
<robot xmlns:xacro="http://ros.org/wiki/xacro">
<xacro:macro name="kr6_r900" params="prefix parent x y z yaw:=0">

  <link name="${prefix}base_link">
    <collision>
      <geometry><mesh filename="package://kr6_r900_cell/meshes/kr6_r900_2/collision/base_link.stl"/></geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
    </collision>
    <inertial>
      <mass value="16.916"/>
      <origin rpy="0 0 0" xyz="-0.037 0 0.109"/>
      <inertia ixx="0.162" ixy="0" ixz="0" iyy="0.109" iyz="0" izz="0.185"/>
    </inertial>
    <visual>
      <geometry><mesh filename="package://kr6_r900_cell/meshes/kr6_r900_2/visual/base_link.dae"/></geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
    </visual>
  </link>

  <link name="${prefix}base"/>

  <link name="${prefix}link_1">
    <collision>
      <geometry><mesh filename="package://kr6_r900_cell/meshes/kr6_r900_2/collision/link_1.stl"/></geometry>
      <origin rpy="-3.14159 0 0" xyz="0 0 0.208"/>
    </collision>
    <inertial>
      <mass value="8.416"/>
      <origin rpy="0 0 0" xyz="0.006 -0.016 -0.107"/>
      <inertia ixx="0.074" ixy="0" ixz="0" iyy="0.089" iyz="0" izz="0.110"/>
    </inertial>
    <visual>
      <geometry><mesh filename="package://kr6_r900_cell/meshes/kr6_r900_2/visual/link_1.dae"/></geometry>
      <origin rpy="-3.14159 0 0" xyz="0 0 0.208"/>
    </visual>
  </link>

  <link name="${prefix}link_2">
    <collision>
      <geometry><mesh filename="package://kr6_r900_cell/meshes/kr6_r900_2/collision/link_2.stl"/></geometry>
      <origin rpy="1.5708 0 1.5708" xyz="-0.4 -0.025 -0.091"/>
    </collision>
    <inertial>
      <mass value="16.793"/>
      <origin rpy="0 0 0" xyz="0.147 -0.004 -0.074"/>
      <inertia ixx="0.548" ixy="0" ixz="0" iyy="0.087" iyz="0" izz="0.589"/>
    </inertial>
    <visual>
      <geometry><mesh filename="package://kr6_r900_cell/meshes/kr6_r900_2/visual/link_2.dae"/></geometry>
      <origin rpy="1.5708 0 1.5708" xyz="-0.4 -0.025 -0.091"/>
    </visual>
  </link>

  <link name="${prefix}link_3">
    <collision>
      <geometry><mesh filename="package://kr6_r900_cell/meshes/kr6_r900_2/collision/link_3.stl"/></geometry>
      <origin rpy="1.5708 0 0" xyz="-0.025 0.855 -0.086"/>
    </collision>
    <inertial>
      <mass value="5.988"/>
      <origin rpy="0 0 0" xyz="0.042 -0.012 -0.068"/>
      <inertia ixx="0.043" ixy="0" ixz="0" iyy="0.019" iyz="0" izz="0.048"/>
    </inertial>
    <visual>
      <geometry><mesh filename="package://kr6_r900_cell/meshes/kr6_r900_2/visual/link_3.dae"/></geometry>
      <origin rpy="1.5708 0 0" xyz="-0.025 0.855 -0.086"/>
    </visual>
  </link>

  <link name="${prefix}link_4">
    <collision>
      <geometry><mesh filename="package://kr6_r900_cell/meshes/kr6_r900_2/collision/link_4.stl"/></geometry>
      <origin rpy="0 1.5708 0" xyz="-0.880 0 0.221"/>
    </collision>
    <inertial>
      <mass value="4.700"/>
      <origin rpy="0 0 0" xyz="0.001 0.009 -0.082"/>
      <inertia ixx="0.010" ixy="0" ixz="0" iyy="0.044" iyz="0" izz="0.047"/>
    </inertial>
    <visual>
      <geometry><mesh filename="package://kr6_r900_cell/meshes/kr6_r900_2/visual/link_4.dae"/></geometry>
      <origin rpy="0 1.5708 0" xyz="-0.880 0 0.221"/>
    </visual>
  </link>

  <link name="${prefix}link_5">
    <collision>
      <geometry><mesh filename="package://kr6_r900_cell/meshes/kr6_r900_2/collision/link_5.stl"/></geometry>
      <origin rpy="1.5708 0 0" xyz="-0.445 0.880 -0.050"/>
    </collision>
    <inertial>
      <mass value="1.613"/>
      <origin rpy="0 0 0" xyz="0.009 0.001 -0.026"/>
      <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.002"/>
    </inertial>
    <visual>
      <geometry><mesh filename="package://kr6_r900_cell/meshes/kr6_r900_2/visual/link_5.dae"/></geometry>
      <origin rpy="1.5708 0 0" xyz="-0.445 0.880 -0.050"/>
    </visual>
  </link>

  <link name="${prefix}link_6">
    <collision>
      <geometry><mesh filename="package://kr6_r900_cell/meshes/kr6_r900_2/collision/link_6.stl"/></geometry>
      <origin rpy="0 1.5708 0" xyz="-0.880 0 0.507"/>
    </collision>
    <inertial>
      <mass value="0.734"/>
      <origin rpy="0 0 0" xyz="0 0 -0.012"/>
      <inertia ixx="0.000184" ixy="0" ixz="0" iyy="0.000182" iyz="0" izz="0.000296"/>
    </inertial>
    <visual>
      <geometry><mesh filename="package://kr6_r900_cell/meshes/kr6_r900_2/visual/link_6.dae"/></geometry>
      <origin rpy="0 1.5708 0" xyz="-0.880 0 0.507"/>
    </visual>
  </link>

  <link name="${prefix}flange"/>
  <link name="${prefix}tool0"/>

  <!-- mount arm to parent link at given offset -->
  <joint name="${prefix}world_to_base" type="fixed">
    <parent link="${parent}"/>
    <child link="${prefix}base_link"/>
    <origin xyz="${x} ${y} ${z}" rpy="0 0 ${yaw}"/>
  </joint>

  <joint name="${prefix}base_link_to_base" type="fixed">
    <parent link="${prefix}base_link"/>
    <child link="${prefix}base"/>
  </joint>

  <joint name="${prefix}joint_1" type="revolute">
    <axis xyz="0 0 1"/>
    <parent link="${prefix}base_link"/>
    <child link="${prefix}link_1"/>
    <origin rpy="3.14159 0 0" xyz="0 0 0.208"/>
    <limit effort="334.8" lower="-2.96706" upper="2.96706" velocity="6.28319"/>
  </joint>

  <joint name="${prefix}joint_2" type="revolute">
    <axis xyz="0 0 1"/>
    <parent link="${prefix}link_1"/>
    <child link="${prefix}link_2"/>
    <origin rpy="1.5708 0 0" xyz="0.025 -0.0907 -0.192"/>
    <limit effort="260.657" lower="-3.31613" upper="0.78540" velocity="5.23599"/>
  </joint>

  <joint name="${prefix}joint_3" type="revolute">
    <axis xyz="0 0 1"/>
    <parent link="${prefix}link_2"/>
    <child link="${prefix}link_3"/>
    <origin rpy="0 0 0" xyz="0.455 0 -0.0042"/>
    <limit effort="137.827" lower="-2.09440" upper="2.72271" velocity="6.28319"/>
  </joint>

  <joint name="${prefix}joint_4" type="revolute">
    <axis xyz="0 0 1"/>
    <parent link="${prefix}link_3"/>
    <child link="${prefix}link_4"/>
    <origin rpy="1.5708 0 -1.5708" xyz="0.196 -0.025 -0.0865"/>
    <limit effort="43.282" lower="-3.22886" upper="3.22886" velocity="7.85398"/>
  </joint>

  <joint name="${prefix}joint_5" type="revolute">
    <axis xyz="0 0 1"/>
    <parent link="${prefix}link_4"/>
    <child link="${prefix}link_5"/>
    <origin rpy="0 1.5708 1.5708" xyz="0 0.0505 -0.224"/>
    <limit effort="45.670" lower="-2.09440" upper="2.09440" velocity="7.85398"/>
  </joint>

  <joint name="${prefix}joint_6" type="revolute">
    <axis xyz="0 0 1"/>
    <parent link="${prefix}link_5"/>
    <child link="${prefix}link_6"/>
    <origin rpy="1.5708 0 -1.5708" xyz="0.0615 0 -0.0505"/>
    <limit effort="23.294" lower="-6.10865" upper="6.10865" velocity="9.42478"/>
  </joint>

  <joint name="${prefix}link6_to_flange" type="fixed">
    <parent link="${prefix}link_6"/>
    <child link="${prefix}flange"/>
    <origin rpy="0 1.5708 0" xyz="0 0 -0.0285"/>
  </joint>

  <joint name="${prefix}link6_to_tool0" type="fixed">
    <parent link="${prefix}link_6"/>
    <child link="${prefix}tool0"/>
    <origin rpy="3.14159 0 3.14159" xyz="0 0 -0.0285"/>
  </joint>

</xacro:macro>
</robot>
