  <!-- JOINTS -->
  <joint name="world-base_link" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
  </joint>

  <joint name="base_link-base" type="fixed">
    <parent link="base_link"/>
    <child link="base"/>
  </joint>

  <joint name="joint_1" type="revolute">
    <axis xyz="0 0 1"/>
    <parent link="base_link"/>
    <child link="link_1"/>
    <origin rpy="3.14159 0 0" xyz="0 0 0.208"/>
    <limit effort="334.8" lower="-2.96706" upper="2.96706" velocity="6.28319"/>
